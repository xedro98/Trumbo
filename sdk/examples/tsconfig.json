{
	"extends": "../../apps/tsconfig.apps.json",
	"compilerOptions": {
		// Environment setup & latest features
		"lib": ["ESNext"],
		"types": ["bun"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"allowJs": true,

		// Bundler mode
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,

		// Best practices
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": false,
		"noImplicitOverride": true,

		// Some stricter flags (disabled by default)
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noPropertyAccessFromIndexSignature": false,
		"paths": {
			"@trembo/agents": ["../packages/agents/src/index.ts"],
			"@trembo/agents/*": [
				"../packages/agents/src/*",
				"../packages/agents/src/*/index.ts"
			],
			"@trembo/trembo-hub": ["./trembo-hub/src/server.ts"],
			"@trembo/core": ["../packages/core/src/index.ts"],
			"@trembo/core/hub/daemon-entry": [
				"../packages/core/src/hub/daemon/entry.ts"
			],
			"@trembo/core/*": [
				"../packages/core/src/*",
				"../packages/core/src/*/index.ts"
			],
			"@trembo/core/telemetry": [
				"../packages/core/src/services/telemetry/index.ts"
			],
			"@trembo/llms": ["../packages/llms/src/index.ts"],
			"@trembo/shared": ["../packages/shared/src/index.ts"],
			"@trembo/shared/storage": ["../packages/shared/src/storage/index.ts"],
			"@trembo/shared/db": ["../packages/shared/src/db/index.ts"],
			"@trembo/shared/*": [
				"../packages/shared/src/*",
				"../packages/shared/src/*/index.ts"
			]
		}
	}
}
