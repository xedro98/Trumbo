{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"root": false,
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noConfusingVoidType": "info",
				"noExplicitAny": "info",
				"noAssignInExpressions": "info",
				"noArrayIndexKey": "info",
				"noUnknownAtRules": {
					"level": "info",
					"options": {
						"ignore": [
							"tailwind",
							"layer",
							"apply",
							"responsive",
							"screen",
							"variants"
						]
					}
				}
			},
			"style": {
				"noNonNullAssertion": "info",
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"patterns": [
							{
								"group": [
									"@trembo/llms/*",
									"@trembo/agents/*",
									"@trembo/core/*",
									"@trembo/shared/*",
									"**/llms/src/**",
									"**/agents/src/**",
									"**/core/src/**",
									"**/shared/src/**",
									"**/rpc/src/**",
									"**/scheduler/src/**",
									"!@trembo/llms/node",
									"!@trembo/llms/browser",
									"!@trembo/llms/runtime",
									"!@trembo/llms/runtime/*",
									"!@trembo/llms/models",
									"!@trembo/llms/models/*",
									"!@trembo/llms/providers",
									"!@trembo/llms/providers/*",
									"!@trembo/agents/node",
									"!@trembo/agents/browser",
									"!@trembo/core/hub",
									"!@trembo/core/telemetry",
									"!@trembo/core/rpc",
									"!@trembo/shared/browser",
									"!@trembo/shared/types",
									"!@trembo/shared/storage",
									"!@trembo/shared/db"
								],
								"message": "Use package entrypoints for cross-package imports. Do not import from another package's internal files."
							}
						]
					}
				}
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"json": {
		"formatter": {
			"enabled": true
		}
	},
	"overrides": [
		{
			"includes": ["docs/**"],
			"linter": {
				"rules": {
					"a11y": {
						"noStaticElementInteractions": "off",
						"useKeyWithClickEvents": "off",
						"noSvgWithoutTitle": "off",
						"useFocusableInteractive": "off",
						"useSemanticElements": "off",
						"useAriaPropsForRole": "off"
					},
					"security": {
						"noDangerouslySetInnerHtml": "off"
					},
					"suspicious": {
						"noDocumentCookie": "off"
					}
				}
			}
		},
		{
			"includes": ["../apps/cli/src/tui/**"],
			"linter": {
				"rules": {
					"a11y": {
						"noStaticElementInteractions": "off",
						"useKeyWithClickEvents": "off"
					}
				}
			}
		}
	]
}
