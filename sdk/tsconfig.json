{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"paths": {
			"@trembo/agents": ["./packages/agents/src/index.ts"],
			"@trembo/agents/*": [
				"./packages/agents/src/*",
				"./packages/agents/src/*/index.ts"
			],
			"@trembo/trembo-hub": ["./apps/trembo-hub/src/server.ts"],
			"@trembo/core": ["./packages/core/src/index.ts"],
			"@trembo/core/hub": ["./packages/core/src/hub/index.ts"],
			"@trembo/core/hub/daemon-entry": [
				"./packages/core/src/hub/daemon/entry.ts"
			],
			"@trembo/core/telemetry": [
				"./packages/core/src/services/telemetry/index.ts"
			],
			"@trembo/core/*": [
				"./packages/core/src/*",
				"./packages/core/src/*/index.ts"
			],
			"@trembo/llms": ["./packages/llms/src/index.ts"],
			"@trembo/llms/browser": ["./packages/llms/src/index.browser.ts"],
			"@trembo/sdk": ["./packages/sdk/src/index.ts"],
			"@trembo/shared": ["./packages/shared/src/index.ts"],
			"@trembo/shared/automation": ["./packages/shared/src/automation/index.ts"],
			"@trembo/shared/browser": ["./packages/shared/src/index.browser.ts"],
			"@trembo/shared/db": ["./packages/shared/src/db/index.ts"],
			"@trembo/shared/storage": ["./packages/shared/src/storage/index.ts"],
			"@trembo/shared/types": ["./packages/shared/src/types/index.ts"],
			"@trembo/shared/*": [
				"./packages/shared/src/*",
				"./packages/shared/src/*/index.ts"
			]
		}
	},
	"include": ["**/*.ts", "**/*.tsx", "**/bun.mts", "../vitest.config.ts"],
	"exclude": [
		"node_modules",
		"**/dist/**",
		"**/.next/**",
		"packages/gateway/**"
	]
}
