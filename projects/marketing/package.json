{
	"name": "@trumbo/marketing",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Trumbo marketing site — static SPA for trumbo.dev on Cloudflare Workers.",
	"scripts": {
		"dev": "vite",
		"dev:api": "wrangler dev --port 8787",
		"db:migrate": "wrangler d1 migrations apply trumbo-marketing-blog --local",
		"build": "vite build",
		"deploy": "vite build && wrangler deploy",
		"typecheck": "tsc -b"
	},
	"dependencies": {
		"@cloudflare/kumo": "^2.6.0",
		"@phosphor-icons/react": "^2.1.10",
		"@tiptap/extension-image": "^3.27.1",
		"@tiptap/extension-link": "^3.27.1",
		"@tiptap/extension-placeholder": "^3.27.1",
		"@tiptap/pm": "^3.27.1",
		"@tiptap/react": "^3.27.1",
		"@tiptap/starter-kit": "^3.27.1",
		"clsx": "^2.1.1",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"tailwind-merge": "^3.5.0",
		"wouter": "^3.3.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250101.0",
		"@tailwindcss/vite": "^4.2.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react-swc": "^4.3.0",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"wrangler": "^4.0.0"
	}
}
