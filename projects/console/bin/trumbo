#!/usr/bin/env node

// Binary resolver for Trumbo CLI.
//
// This script runs with Node.js (available everywhere npm is) and finds the
// correct platform-specific compiled binary to execute. The compiled binary
// has Bun embedded, so users don't need Bun installed.
//
// Resolution order:
// 1. TRUMBO_BIN_PATH env var override
// 2. Stable local cache outside node_modules (Windows: %LOCALAPPDATA%\Trumbo\bin)
// 3. Cached binary at bin/.trumbo beside this wrapper
// 4. require.resolve + walk up node_modules to find the platform package

const childProcess = require("child_process");
const fs = require("fs");
const path = require("path");
const os = require("os");

const scriptPath = fs.realpathSync(__filename);
const scriptDir = path.dirname(scriptPath);
const childEnv = {
	...process.env,
	TRUMBO_WRAPPER_PATH: scriptPath,
};

function run(target) {
	const args = process.argv.slice(2);
	const spawnOptions = {
		stdio: "inherit",
		env: childEnv,
		windowsHide: false,
	};

	// On Windows, spawnSync can detach the compiled binary from the interactive
	// console; async spawn keeps stdin/stdout as real TTYs for OpenTUI.
	if (process.platform === "win32") {
		const child = childProcess.spawn(target, args, spawnOptions);
		child.on("error", function (err) {
			console.error(err.message);
			process.exit(1);
		});
		child.on("exit", function (code, signal) {
			if (signal) {
				process.kill(process.pid, signal);
			}
			process.exit(code === null ? 1 : code);
		});
		return;
	}

	const result = childProcess.spawnSync(target, args, spawnOptions);
	if (result.error) {
		console.error(result.error.message);
		process.exit(1);
	}
	if (typeof result.status === "number") {
		process.exit(result.status);
	}
	if (result.signal) {
		process.kill(process.pid, result.signal);
		process.exit(128);
	}
	process.exit(1);
}

function localRuntimeBinaryPath() {
	if (process.platform === "win32") {
		const base =
			process.env.LOCALAPPDATA || path.join(os.homedir(), "AppData", "Local");
		return path.join(base, "Trumbo", "bin", "trumbo.exe");
	}
	return path.join(os.homedir(), ".trumbo", "bin", "trumbo");
}

function readLocalRuntimeBinaryPath() {
	const target = localRuntimeBinaryPath();
	if (fs.existsSync(target)) {
		return target;
	}
	if (process.platform !== "win32") {
		return undefined;
	}
	const pointer = path.join(path.dirname(target), "current.txt");
	if (!fs.existsSync(pointer)) {
		return undefined;
	}
	const fileName = fs.readFileSync(pointer, "utf8").trim();
	if (!fileName) {
		return undefined;
	}
	const resolved = path.join(path.dirname(target), fileName);
	return fs.existsSync(resolved) ? resolved : undefined;
}

// 1. Check env var override
const envPath = process.env.TRUMBO_BIN_PATH;
if (envPath) {
	run(envPath);
}

// 2. Stable cache outside node_modules (survives npm EBUSY on Windows)
const localRuntime = readLocalRuntimeBinaryPath();
if (localRuntime) {
	run(localRuntime);
}

// 3. Cached binary beside wrapper
const cachedNames =
	process.platform === "win32" ? [".trumbo.exe", ".trumbo"] : [".trumbo"];
for (const cachedName of cachedNames) {
	const cached = path.join(scriptDir, cachedName);
	if (fs.existsSync(cached)) {
		run(cached);
	}
}

// 4. Detect platform and architecture
const platformMap = {
	darwin: "darwin",
	linux: "linux",
	win32: "windows",
};
const archMap = {
	x64: "x64",
	arm64: "arm64",
};

let platform = platformMap[os.platform()];
if (!platform) {
	platform = os.platform();
}
let arch = archMap[os.arch()];
if (!arch) {
	arch = os.arch();
}

const base = "@trumbodev/cli-" + platform + "-" + arch;
const binary = platform === "windows" ? "trumbo.exe" : "trumbo";

// Build fallback chain of package names to try
const names = [base];

function resolveViaRequire(packageName) {
	try {
		const requireFn = require("module").createRequire(scriptPath);
		const packageJsonPath = requireFn.resolve(packageName + "/package.json");
		const candidate = path.join(path.dirname(packageJsonPath), "bin", binary);
		if (fs.existsSync(candidate)) {
			return candidate;
		}
	} catch (_error) {
		// Package not installed — fall through to node_modules walk.
	}
	return undefined;
}

function findBinary(startDir) {
	for (const name of names) {
		const viaRequire = resolveViaRequire(name);
		if (viaRequire) {
			return viaRequire;
		}
	}

	let current = startDir;
	for (;;) {
		const modules = path.join(current, "node_modules");
		if (fs.existsSync(modules)) {
			for (const name of names) {
				// Scoped package: @trumbodev/cli-darwin-arm64 lives at
				// node_modules/@trumbodev/cli-darwin-arm64
				const candidate = path.join(modules, name, "bin", binary);
				if (fs.existsSync(candidate)) return candidate;
			}
		}
		const parent = path.dirname(current);
		if (parent === current) {
			return undefined;
		}
		current = parent;
	}
}

function wrapperVersion() {
	try {
		const requireFn = require("module").createRequire(scriptPath);
		return requireFn("../package.json").version || "latest";
	} catch (_error) {
		return "latest";
	}
}

function installHelp() {
	const lines = [
		"Try reinstalling:",
		"  npm install -g @trumbodev/cli",
	];
	if (process.platform === "win32") {
		const local = readLocalRuntimeBinaryPath();
		lines.push(
			"",
			"On Windows, close any running Trumbo processes first, then run:",
			"  npm install -g --force @trumbodev/cli --allow-scripts=@trumbodev/cli",
			"",
			"If npm reports EBUSY/EPERM, stop Trumbo and delete stale folders:",
			'  Get-Process trumbo -ErrorAction SilentlyContinue | Stop-Process -Force',
			'  Remove-Item -Recurse -Force "$env:APPDATA\\npm\\node_modules\\@trumbodev\\.cli-*" -ErrorAction SilentlyContinue',
			"",
			"If that still fails, install the platform package directly:",
			"  npm install -g " + base + "@" + wrapperVersion(),
		);
		if (local) {
			lines.push("", "Cached binary found at:", "  " + local);
		}
	}
	return lines.join("\n");
}

const resolved = findBinary(scriptDir);
if (!resolved) {
	console.error(
		"Could not find the Trumbo CLI binary for your platform.\n" +
			"Your platform: " +
			os.platform() +
			" " +
			os.arch() +
			"\n" +
			"Looked for: " +
			names.map(function (n) {
				return '"' + n + '"';
			}).join(" or ") +
			"\n\n" +
			installHelp(),
	);
	process.exit(1);
}

run(resolved);
