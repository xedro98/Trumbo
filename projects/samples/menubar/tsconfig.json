{
	"extends": "../../../engine/packages/tsconfig.base.json",
	"compilerOptions": {
		"outDir": "dist",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ESNext",
		"paths": {
			"@trumbo/agents": ["../../../engine/packages/agents/src/index.ts"],
			"@trumbo/agents/*": [
				"../../../engine/packages/agents/src/*",
				"../../../engine/packages/agents/src/*/index.ts"
			],
			"@trumbo/core": ["../../../engine/packages/core/src/index.ts"],
			"@trumbo/core/hub/daemon-entry": [
				"../../../engine/packages/core/src/hub/daemon/entry.ts"
			],
			"@trumbo/core/*": [
				"../../../engine/packages/core/src/*",
				"../../../engine/packages/core/src/*/index.ts"
			],
			"@trumbo/llms": ["../../../engine/packages/llms/src/index.ts"],
			"@trumbo/shared": ["../../../engine/packages/shared/src/index.ts"],
			"@trumbo/shared/storage": [
				"../../../engine/packages/shared/src/storage/index.ts"
			],
			"@trumbo/shared/db": ["../../../engine/packages/shared/src/db/index.ts"],
			"@trumbo/shared/*": [
				"../../../engine/packages/shared/src/*",
				"../../../engine/packages/shared/src/*/index.ts"
			]
		}
	},
	"include": ["sidecar/**/*.ts"]
}
