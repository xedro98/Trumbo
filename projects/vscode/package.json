{
	"name": "trumbo",
	"displayName": "Trumbo",
	"description": "Autonomous coding agent right in your IDE, capable of creating/editing files, running commands, using the browser, and more with your permission every step of the way.",
	"version": "0.1.3",
	"icon": "assets/icons/icon.png",
	"engines": {
		"vscode": "^1.106.0"
	},
	"author": {
		"name": "Maxfense, Inc"
	},
	"license": "Apache-2.0",
	"publisher": "trumbo",
	"repository": {
		"type": "git",
		"url": "https://github.com/xedro98/Trumbo"
	},
	"homepage": "https://trumbo.dev",
	"bugs": {
		"url": "https://github.com/xedro98/Trumbo/issues"
	},
	"qna": "https://github.com/xedro98/Trumbo/discussions",
	"galleryBanner": {
		"color": "#141618",
		"theme": "dark"
	},
	"categories": [
		"AI",
		"Chat",
		"Programming Languages",
		"Education",
		"Snippets",
		"Testing"
	],
	"keywords": [
		"trumbo",
		"mcp",
		"openrouter",
		"coding",
		"agent",
		"autonomous",
		"ai"
	],
	"activationEvents": [
		"onLanguage",
		"onUri",
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"icons": {
			"trumbo-icon": {
				"description": "trumbo",
				"default": {
					"fontPath": "assets/icons/trumbo-icon.woff",
					"fontCharacter": "\\e900"
				}
			}
		},
		"walkthroughs": [
			{
				"id": "TrumboWalkthrough",
				"title": "Meet Trumbo, your new coding partner",
				"description": "Trumbo codes like a developer because it thinks like one. Here are 5 ways to put it to work:",
				"steps": [
					{
						"id": "welcome",
						"title": "Start with a Goal, Not Just a Prompt",
						"description": "Tell Trumbo what you want to achieve. It plans, asks, and then codes, like a true partner.",
						"media": {
							"markdown": "walkthrough/step1.md"
						}
					},
					{
						"id": "learn",
						"title": "Let Trumbo Learn Your Codebase",
						"description": "Point Trumbo to your project. It builds understanding to make smart, context-aware changes.",
						"media": {
							"markdown": "walkthrough/step2.md"
						}
					},
					{
						"id": "advanced-features",
						"title": "Always Use the Best AI Models",
						"description": "Trumbo empowers you with State-of-the-art AI, connecting to top models (Anthropic, Gemini, OpenAI & more).",
						"media": {
							"markdown": "walkthrough/step3.md"
						}
					},
					{
						"id": "mcp",
						"title": "Extend with Powerful Tools (MCP)",
						"description": "Connect to databases, APIs, and other external tools through MCP.",
						"media": {
							"markdown": "walkthrough/step4.md"
						}
					},
					{
						"id": "getting-started",
						"title": "You're Always in Control",
						"description": "Review Trumbo's plans and diffs. Approve changes before they happen. No surprises.",
						"media": {
							"markdown": "walkthrough/step5.md"
						},
						"content": {
							"path": "walkthrough/step5.md"
						}
					}
				]
			}
		],
		"viewsContainers": {
			"secondarySidebar": [
				{
					"id": "trumbo-SecondarySidebar",
					"title": "Trumbo",
					"icon": "assets/icons/icon.svg"
				}
			]
		},
		"views": {
			"trumbo-SecondarySidebar": [
				{
					"type": "webview",
					"id": "trumbo.SidebarProvider",
					"name": "Trumbo",
					"icon": "assets/icons/icon.svg"
				}
			]
		},
		"commands": [
			{
				"command": "trumbo.plusButtonClicked",
				"title": "New Task",
				"icon": "$(add)"
			},
			{
				"command": "trumbo.mcpButtonClicked",
				"title": "MCP Servers",
				"icon": "$(server)"
			},
			{
				"command": "trumbo.marketplaceButtonClicked",
				"title": "Customize",
				"icon": "$(wrench)"
			},
			{
				"command": "trumbo.historyButtonClicked",
				"title": "History",
				"icon": "$(history)"
			},
			{
				"command": "trumbo.accountButtonClicked",
				"title": "Account",
				"icon": "$(account)"
			},
			{
				"command": "trumbo.settingsButtonClicked",
				"title": "Settings",
				"icon": "$(settings-gear)"
			},
			{
				"command": "trumbo.dev.createTestTasks",
				"title": "Create Test Tasks",
				"category": "Trumbo",
				"when": "trumbo.isDevMode"
			},
			{
				"command": "trumbo.dev.expireMcpOAuthTokens",
				"title": "Expire MCP OAuth Tokens (for testing)",
				"category": "Trumbo",
				"when": "trumbo.isDevMode"
			},
			{
				"command": "trumbo.addToChat",
				"title": "Add to Trumbo",
				"category": "Trumbo"
			},
			{
				"command": "trumbo.addTerminalOutputToChat",
				"title": "Add to Trumbo",
				"category": "Trumbo"
			},
			{
				"command": "trumbo.focusChatInput",
				"title": "Jump to Chat Input",
				"category": "Trumbo"
			},
			{
				"command": "trumbo.openInSidebar",
				"title": "Open in Right Sidebar",
				"category": "Trumbo"
			},
			{
				"command": "trumbo.openInPanel",
				"title": "Open in Editor Tab",
				"category": "Trumbo"
			},
			{
				"command": "trumbo.openInActivityBar",
				"title": "Open in Left Sidebar",
				"category": "Trumbo"
			},
			{
				"command": "trumbo.generateGitCommitMessage",
				"title": "Generate Commit Message with Trumbo",
				"category": "Trumbo",
				"icon": "$(trumbo-icon)"
			},
			{
				"command": "trumbo.abortGitCommitMessage",
				"title": "Generate Commit Message with Trumbo - Stop",
				"category": "Trumbo",
				"icon": "$(debug-stop)"
			},
			{
				"command": "trumbo.explainCode",
				"title": "Explain with Trumbo",
				"category": "Trumbo"
			},
			{
				"command": "trumbo.improveCode",
				"title": "Improve with Trumbo",
				"category": "Trumbo"
			},
			{
				"command": "trumbo.jupyterGenerateCell",
				"title": "Generate Jupyter Cell with Trumbo",
				"category": "Trumbo",
				"icon": "$(sparkle)"
			},
			{
				"command": "trumbo.jupyterExplainCell",
				"title": "Explain Jupyter Cell with Trumbo",
				"category": "Trumbo",
				"icon": "$(question)"
			},
			{
				"command": "trumbo.jupyterImproveCell",
				"title": "Improve Jupyter Cell with Trumbo",
				"category": "Trumbo",
				"icon": "$(lightbulb)"
			},
			{
				"command": "trumbo.openWalkthrough",
				"title": "Open Walkthrough",
				"category": "Trumbo"
			},
			{
				"command": "trumbo.reconstructTaskHistory",
				"title": "Reconstruct Task History",
				"category": "Trumbo"
			}
		],
		"keybindings": [
			{
				"command": "trumbo.addToChat",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "editorHasSelection"
			},
			{
				"command": "trumbo.generateGitCommitMessage",
				"when": "config.git.enabled && scmProvider == git"
			},
			{
				"command": "trumbo.focusChatInput",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "!editorHasSelection"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "trumbo.plusButtonClicked",
					"group": "navigation@1",
					"when": "view == trumbo.SidebarProvider"
				},
				{
					"command": "trumbo.marketplaceButtonClicked",
					"group": "navigation@2",
					"when": "view == trumbo.SidebarProvider"
				},
				{
					"command": "trumbo.historyButtonClicked",
					"group": "navigation@3",
					"when": "view == trumbo.SidebarProvider"
				},
				{
					"command": "trumbo.accountButtonClicked",
					"group": "navigation@5",
					"when": "view == trumbo.SidebarProvider"
				},
				{
					"command": "trumbo.settingsButtonClicked",
					"group": "navigation@6",
					"when": "view == trumbo.SidebarProvider"
				},
				{
					"command": "trumbo.openInPanel",
					"group": "navigation@7",
					"when": "view == trumbo.SidebarProvider"
				},
				{
					"command": "trumbo.openInSidebar",
					"group": "navigation@8",
					"when": "view == trumbo.SidebarProvider"
				}
			],
			"editor/context": [
				{
					"command": "trumbo.addToChat",
					"group": "navigation",
					"when": "editorHasSelection"
				}
			],
			"terminal/context": [
				{
					"command": "trumbo.addTerminalOutputToChat",
					"group": "navigation"
				}
			],
			"scm/title": [
				{
					"command": "trumbo.generateGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && !trumbo.isGeneratingCommit"
				},
				{
					"command": "trumbo.abortGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && trumbo.isGeneratingCommit"
				}
			],
			"notebook/toolbar": [
				{
					"command": "trumbo.jupyterGenerateCell",
					"group": "navigation/add@1",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"notebook/cell/title": [
				{
					"command": "trumbo.jupyterExplainCell",
					"group": "inline@1",
					"when": "notebookType == 'jupyter-notebook'"
				},
				{
					"command": "trumbo.jupyterImproveCell",
					"group": "inline@2",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"commandPalette": [
				{
					"command": "trumbo.generateGitCommitMessage",
					"when": "config.git.enabled && !trumbo.isGeneratingCommit"
				},
				{
					"command": "trumbo.abortGitCommitMessage",
					"when": "config.git.enabled && trumbo.isGeneratingCommit"
				}
			]
		},
		"configuration": {
			"title": "Trumbo",
			"properties": {
				"trumbo.preferredLocation": {
					"type": "string",
					"enum": [
						"sidebar",
						"panel",
						"activitybar"
					],
					"enumDescriptions": [
						"Open Trumbo in the right secondary sidebar (default, matches Codex and Claude Code).",
						"Open Trumbo in an editor tab beside your code.",
						"Open Trumbo in the left primary sidebar."
					],
					"default": "sidebar",
					"description": "Default location for the Trumbo chat surface."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "bun run package && node scripts/sanitize-marketplace-bundle.mjs",
		"compile": "bun run check-types && bun run lint && bun esbuild.mjs",
		"compile-standalone": "bun run check-types && bun run lint && bun esbuild.mjs --standalone",
		"postcompile-standalone": "node scripts/package-standalone.mjs",
		"dev": "bun run protos && bun run watch",
		"watch": "bun run --parallel watch:esbuild watch:tsc",
		"watch:esbuild": "bun esbuild.mjs --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "bun run check-types && bun run build:webview && bun run lint && bun esbuild.mjs --production",
		"package:vsix": "vsce package --no-dependencies --no-yarn --allow-star-activation",
		"protos": "node scripts/build-proto.mjs",
		"protos-python": "node scripts/build-python-proto.mjs",
		"download-ripgrep": "node scripts/download-ripgrep.mjs",
		"postprotos": "biome format --config-path ./biome.jsonc src/shared/proto src/core/controller src/hosts/ webview-ui/src/services src/generated --write --no-errors-on-unmatched",
		"clean:build": "rimraf dist dist-standalone webview-ui/build src/generated out/",
		"clean:deps": "rimraf node_modules webview-ui/node_modules",
		"clean:all": "bun run clean:build && bun run clean:deps",
		"compile-tests": "node ./scripts/build-tests.js",
		"watch-tests": "tsc -p . -w --outDir out",
		"check-types": "bun run protos && bunx tsc --noEmit && cd webview-ui && bunx tsc --noEmit",
		"lint": "biome lint --config-path ./biome.jsonc --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error && bun run lint:proto",
		"lint:proto": "node scripts/proto-lint.mjs",
		"analyze:unused": "bunx --yes knip --config knip.json --include files,exports,types,enumMembers,duplicates",
		"analyze:unused:prod": "bunx --yes knip --config knip.json --production --include files,exports,types,enumMembers,dependencies",
		"analyze:unused:fix-exports": "node scripts/remove-unused-exports.mjs --apply",
		"analyze:unused:fix-exports:dry": "node scripts/remove-unused-exports.mjs",
		"format": "biome format --config-path ./biome.jsonc --changed --since main --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error --semicolons=as-needed",
		"format:fix": "biome check --config-path ./biome.jsonc --changed --since main --no-errors-on-unmatched --files-ignore-unknown=true --write --semicolons=as-needed",
		"fix:all": "biome check --config-path ./biome.jsonc --no-errors-on-unmatched --files-ignore-unknown=true --write --diagnostic-level=error --unsafe --semicolons=as-needed",
		"ci:check-all": "bun run --parallel check-types lint format",
		"ci:build": "bun run protos && bun run build:webview && bun esbuild.mjs && bun run compile-tests",
		"pretest": "bun run compile && bun run compile-tests && bun run compile-standalone && bun run lint",
		"test": "bun run test:unit && bun run test:integration",
		"test:integration": "bun run compile-tests && vscode-test",
		"test:unit": "bun scripts/run-bun-unit-tests.ts",
		"test:vitest": "vitest run --config vitest.config.ts",
		"test:vitest:watch": "vitest --config vitest.config.ts",
		"test:bun": "bun scripts/run-bun-tests.ts",
		"test:bun:unit": "bun scripts/run-bun-unit-tests.ts",
		"test:coverage": "bun run compile-tests && vscode-test --coverage",
		"test:sca-server": "bun --watch scripts/test-standalone-core-api-server.ts",
		"test:tp-orchestrator": "bun scripts/testing-platform-orchestrator.ts",
		"dev:mcp-oauth-test-server": "bun src/dev/mcp-oauth-test-server/server.ts",
		"e2e": "playwright test -c playwright.config.ts",
		"test:e2e:build": "vsce package --no-dependencies --allow-package-secrets sendgrid --out dist/e2e.vsix",
		"test:e2e": "playwright install && bun run test:e2e:build && node src/test/e2e/utils/build.mjs && playwright test",
		"test:e2e:optimal": "bun run test:e2e:build && node src/test/e2e/utils/build.mjs && playwright test",
		"test:e2e:ui": "bun scripts/interactive-playwright.ts",
		"install:all": "bun install",
		"dev:webview": "cd webview-ui && bun run dev",
		"build:webview": "bun run protos && cd webview-ui && bun run build",
		"test:webview": "cd webview-ui && bun run test",
		"publish:marketplace": "node scripts/publish-marketplace.mjs",
		"publish:marketplace:prerelease": "node scripts/publish-marketplace.mjs --pre-release",
		"publish:marketplace:nightly": "node ./scripts/publish-nightly.mjs",
		"docs": "cd docs && bun run dev",
		"docs:check-links": "cd docs && bun run check",
		"docs:rename-file": "cd docs && bun run rename",
		"report-issue": "node scripts/report-issue.js",
		"storybook": "cd webview-ui && bun run storybook",
		"eval:smoke:run": "bun evals/smoke-tests/run-smoke-tests.ts"
	},
	"lint-staged": {
		"src/shared/storage/state-keys.ts": [
			"node scripts/generate-state-proto.mjs",
			"git add projects/vscode/proto/trumbo/state.proto"
		],
		"*": [
			"biome check --write --staged --no-errors-on-unmatched --files-ignore-unknown=true --semicolons=as-needed"
		]
	},
