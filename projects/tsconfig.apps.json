{
	"compilerOptions": {
		"paths": {
			"@trumbodev/agents": ["../engine/packages/agents/src/index.ts"],
			"@trumbodev/agents/*": [
				"../engine/packages/agents/src/*",
				"../engine/packages/agents/src/*/index.ts"
			],
			"@trumbodev/hub": ["./hub/src/server.ts"],
			"@trumbodev/core": ["../engine/packages/core/src/index.ts"],
			"@trumbodev/core/hub/daemon-entry": [
				"../engine/packages/core/src/hub/daemon/entry.ts"
			],
			"@trumbodev/core/*": [
				"../engine/packages/core/src/*",
				"../engine/packages/core/src/*/index.ts"
			],
			"@trumbodev/core/telemetry": [
				"../engine/packages/core/src/services/telemetry/index.ts"
			],
			"@trumbodev/llms": ["../engine/packages/llms/src/index.ts"],
			"@trumbodev/shared": ["../engine/packages/shared/src/index.ts"],
			"@trumbodev/shared/storage": [
				"../engine/packages/shared/src/storage/index.ts"
			],
			"@trumbodev/shared/db": ["../engine/packages/shared/src/db/index.ts"],
			"@trumbodev/shared/*": [
				"../engine/packages/shared/src/*",
				"../engine/packages/shared/src/*/index.ts"
			]
		}
	}
}
