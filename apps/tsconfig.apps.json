{
	"compilerOptions": {
		"paths": {
			"@trembo/agents": ["../sdk/packages/agents/src/index.ts"],
			"@trembo/agents/*": [
				"../sdk/packages/agents/src/*",
				"../sdk/packages/agents/src/*/index.ts"
			],
			"@trembo/trembo-hub": ["./trembo-hub/src/server.ts"],
			"@trembo/core": ["../sdk/packages/core/src/index.ts"],
			"@trembo/core/hub/daemon-entry": [
				"../sdk/packages/core/src/hub/daemon/entry.ts"
			],
			"@trembo/core/*": [
				"../sdk/packages/core/src/*",
				"../sdk/packages/core/src/*/index.ts"
			],
			"@trembo/core/telemetry": [
				"../sdk/packages/core/src/services/telemetry/index.ts"
			],
			"@trembo/llms": ["../sdk/packages/llms/src/index.ts"],
			"@trembo/shared": ["../sdk/packages/shared/src/index.ts"],
			"@trembo/shared/storage": ["../sdk/packages/shared/src/storage/index.ts"],
			"@trembo/shared/db": ["../sdk/packages/shared/src/db/index.ts"],
			"@trembo/shared/*": [
				"../sdk/packages/shared/src/*",
				"../sdk/packages/shared/src/*/index.ts"
			]
		}
	}
}
